---
/**
 * Sticky navigation bar.
 *
 * Shows brand name, nav links, and a placeholder slot for the
 * wallet connect island (added in a later unit).
 *
 * Mobile hamburger uses an inline <script> for zero-React interactivity.
 */
import { BRANDING } from "@/config/branding";
import WalletController from "@/components/auth/WalletController";
---

<nav
  class="sticky top-0 z-50 border-b border-course-border bg-course-surface supports-[padding:env(safe-area-inset-top)]:pt-[env(safe-area-inset-top)]"
  id="main-nav"
>
  <div class="flex h-16 items-center justify-between px-4 sm:px-6">
    <!-- Brand -->
    <a
      href="/"
      class="flex items-center gap-2.5 text-mn-text transition-colors hover:text-mn-primary"
      aria-label="Home"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="shrink-0"
      >
        <path d="M3 11.5 12 4l9 7.5"></path>
        <path d="M5 10v9a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9"></path>
      </svg>
      <span class="text-lg font-semibold font-heading">{BRANDING.name}</span>
    </a>

    <!-- Desktop nav (hidden on mobile) -->
    <div class="hidden sm:flex sm:items-center sm:gap-6">
      <a
        href="/"
        class="min-h-[44px] flex items-center text-sm transition-colors hover:text-mn-text text-mn-text"
      >
        Learn
      </a>
      <a
        href="/dashboard"
        class="min-h-[44px] flex items-center text-sm transition-colors hover:text-mn-text text-mn-text-muted"
      >
        Dashboard
      </a>
      <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle color theme">
        <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
      </button>
      <WalletController client:only="react" />
    </div>

    <!-- Mobile controls -->
    <div class="flex items-center gap-1 sm:hidden">
    <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle color theme">
      <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
    </button>
    <!-- Mobile hamburger -->
    <button
      type="button"
      class="flex h-11 w-11 items-center justify-center rounded-sm text-mn-text transition-colors hover:bg-course-surface"
      aria-label="Open menu"
      aria-expanded="false"
      id="nav-mobile-toggle"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
        class="nav-icon-menu"
      >
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        aria-hidden="true"
        class="nav-icon-close hidden"
      >
        <path d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>
    </div>
  </div>

  <!-- Mobile dropdown menu (hidden by default) -->
  <div
    id="nav-mobile-menu"
    class="hidden absolute left-0 right-0 z-50 border-b border-course-border bg-course-surface sm:hidden supports-[padding:env(safe-area-inset-left)]:pl-[env(safe-area-inset-left)] supports-[padding:env(safe-area-inset-right)]:pr-[env(safe-area-inset-right)]"
  >
    <div class="flex flex-col gap-2 px-4 py-4">
      <a
        href="/"
        class="min-h-[44px] flex items-center rounded-sm px-3 text-sm transition-colors hover:bg-course-surface text-mn-text"
      >
        Learn
      </a>
      <a
        href="/dashboard"
        class="min-h-[44px] flex items-center rounded-sm px-3 text-sm transition-colors hover:bg-course-surface text-mn-text-muted"
      >
        Dashboard
      </a>
      <div class="pt-2 border-t border-course-border">
        <WalletController client:only="react" />
      </div>
    </div>
  </div>

  <!-- Mobile backdrop -->
  <div
    id="nav-mobile-backdrop"
    class="hidden fixed inset-0 top-16 z-40 bg-black/50 sm:hidden"
    aria-hidden="true"
  ></div>
</nav>

<script>
  const toggle = document.getElementById("nav-mobile-toggle");
  const menu = document.getElementById("nav-mobile-menu");
  const backdrop = document.getElementById("nav-mobile-backdrop");
  const iconMenu = toggle?.querySelector(".nav-icon-menu");
  const iconClose = toggle?.querySelector(".nav-icon-close");

  let open = false;

  function setOpen(value: boolean) {
    open = value;
    menu?.classList.toggle("hidden", !open);
    backdrop?.classList.toggle("hidden", !open);
    iconMenu?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  }

  toggle?.addEventListener("click", () => setOpen(!open));
  backdrop?.addEventListener("click", () => setOpen(false));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && open) setOpen(false);
  });

  // Theme toggle — flips data-theme on <html> and persists the choice.
  // Initial theme is applied pre-paint by the bootstrap in BaseLayout.
  document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isDark =
        document.documentElement.getAttribute("data-theme") === "dark";
      const next = isDark ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try {
        localStorage.setItem("theme", next);
      } catch (e) {
        /* ignore */
      }
    });
  });
</script>
