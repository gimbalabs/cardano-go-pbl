---
/**
 * Footer — a spec-block: wordmark + a monospace stack line, with links.
 */
import { BRANDING } from "@/config/branding";
import { CURRENT_NETWORK } from "@/config/network";
---

<footer
  class="border-t border-course-border bg-course-surface py-8 supports-[padding:env(safe-area-inset-bottom)]:pb-[calc(2rem+env(safe-area-inset-bottom))]"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <div>
        <p class="font-heading text-sm font-semibold text-mn-text">{BRANDING.name}</p>
        <p class="mt-1 font-mono text-xs text-mn-text-muted">
          astro · go · cardano <span class="text-structure">·</span> network: {CURRENT_NETWORK.cardanoNetwork}
        </p>
      </div>
      <div class="flex items-center gap-4 font-mono text-xs uppercase tracking-wider sm:gap-6">
        <a
          href={BRANDING.links.andamio}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[44px] items-center text-mn-text-muted transition-colors hover:text-link"
        >
          Andamio
        </a>
        <a
          href={BRANDING.links.docs}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[44px] items-center text-mn-text-muted transition-colors hover:text-link"
        >
          Docs
        </a>
        <a
          href={BRANDING.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[44px] items-center text-mn-text-muted transition-colors hover:text-link"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</footer>
