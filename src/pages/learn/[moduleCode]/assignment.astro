---
/**
 * Assignment Page
 *
 * Displays the assignment prompt for a module. The interactive
 * submission/enrollment UI will be added as a React island in Unit 5.
 *
 * Route: /learn/:moduleCode/assignment
 */
import AppLayout from "@/layouts/AppLayout.astro";
import { fetchModuleDetail, fetchSLTs, fetchAssignment } from "@/lib/gateway.server";
import { renderMarkdown } from "@/lib/markdown";
import { CURRENT_NETWORK } from "@/config/network";
import { getPageTitle } from "@/config/branding";
import AssignmentInteractive from "@/components/assignment/AssignmentInteractive";

const { moduleCode } = Astro.params;
const courseId = CURRENT_NETWORK.courseId;

if (!courseId || !moduleCode) {
  return Astro.redirect("/");
}

// Fetch module detail, SLTs, and assignment content in parallel
const [module, slts, assignment] = await Promise.all([
  fetchModuleDetail(courseId, moduleCode),
  fetchSLTs(courseId, moduleCode),
  fetchAssignment(courseId, moduleCode),
]);

if (!module) {
  return new Response("Module not found", { status: 404 });
}

// Render assignment content to HTML
const contentHtml = assignment ? renderMarkdown(assignment.contentJson) : "";

const sortedSlts = [...slts].sort(
  (a, b) => (a.moduleIndex ?? 0) - (b.moduleIndex ?? 0)
);

// First lesson of the module — target for "Back to module".
const firstIndex = sortedSlts[0]?.moduleIndex ?? 1;

const title = getPageTitle(`Assignment: ${module.title ?? moduleCode}`);
---

<AppLayout title={title}>
  <div class="assignment-split">
    <!-- Left: assignment description / rubric -->
    <div class="assignment-desc">
      <div class="assignment-progress" aria-hidden="true"></div>
      <div class="assignment-desc-inner">
        <nav class="assignment-breadcrumb" aria-label="Breadcrumb">
          <a href={`/learn/${moduleCode}/${firstIndex}`} class="assignment-crumb-link">
            <svg
              width="14"
              height="14"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M10 12L6 8l4-4"></path>
            </svg>
            <span>{module.title ?? "Module"}</span>
          </a>
          <span class="assignment-crumb-sep" aria-hidden="true">·</span>
          <span class="assignment-crumb-current">Assignment</span>
        </nav>

        <h1 class="assignment-title">
          {assignment?.title ?? `${module.title ?? "Module"} Assignment`}
        </h1>
        {assignment?.description && (
          <p class="assignment-lede">{assignment.description}</p>
        )}

        {sortedSlts.length > 0 && (
          <div class="assignment-slts">
            <p class="assignment-slts-head">What you'll demonstrate</p>
            <ul class="assignment-slts-list">
              {sortedSlts.map((slt, idx) => (
                <li class="assignment-slt">
                  <span class="assignment-slt-index">{slt.moduleIndex ?? idx + 1}</span>
                  <span>{slt.sltText ?? `Lesson ${idx + 1}`}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {assignment && contentHtml ? (
          <article class="prose prose-course assignment-body" set:html={contentHtml} />
        ) : (
          <div class="mt-6 rounded-lg border border-course-border bg-course-card p-6 text-center">
            <p class="text-mn-text-muted">
              No assignment available for this module yet.
            </p>
          </div>
        )}
      </div>
    </div>

    <!-- Right: work surface (cobalt field + floating card) -->
    <div class="assignment-work">
      <div class="assignment-work-art" aria-hidden="true"></div>
      <div class="assignment-card">
        <AssignmentInteractive
          client:only="react"
          courseId={courseId}
          moduleCode={moduleCode}
          sltHash={module.sltHash ?? null}
        />
      </div>
    </div>
  </div>
</AppLayout>
